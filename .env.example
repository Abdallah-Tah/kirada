APP_NAME=Kirada
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://kirada.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database (MySQL/MariaDB)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kirada
DB_USERNAME=kirada
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.kirada.example.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (configure with real SMTP in production)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@kirada.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# File storage (private disk for documents + payment proofs)
# Files are stored on the local 'private' disk by default.
# For multi-server or S3, update FILESYSTEM_DISK and AWS config below.
FILESYSTEM_DISK=local

# AWS S3 (optional, for shared file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# OpenAI (optional — enables AI Assistant; leave empty to disable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Initial admin (used only by AdminUserSeeder in production)
KIRADA_ADMIN_EMAIL=admin@kirada.dj
KIRADA_ADMIN_PASSWORD=ChangeMe123!

# Kirada feature flags (future use)
# SUBSCRIPTION_ENFORCEMENT=false

VITE_APP_NAME="${APP_NAME}"
# Google Maps JavaScript API key with Places API enabled
VITE_GOOGLE_MAPS_API_KEY=
